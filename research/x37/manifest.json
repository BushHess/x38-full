    "required_fields": [
      "id",
      "path",
      "status",
      "agent",
      "prompt_version",
      "started_at",
      "phase_reached",
      "verdict",
      "notes"
    ],
    "field_notes": {
      "id": "must match directory name under sessions/, e.g. s01_codex_v4",
      "path": "must be sessions/<id>/",
      "status": "one of PLANNED, ACTIVE, DONE, ABANDONED",
      "agent": "human-readable agent or model label",
      "prompt_version": "currently V4 unless x37 root prompt is changed later",
      "started_at": "YYYY-MM-DD",
      "phase_reached": "0, 1, 2, 3, 4, 5, or 6",
      "verdict": "null or one of SUPERIOR, COMPETITIVE, NO_ROBUST_IMPROVEMENT, ABANDONED",
      "notes": "short human-readable note; nullable"
    }
  },
  "editable_session_statuses": [
    "PLANNED",
    "ACTIVE"
  ],
  "closed_session_statuses": [
